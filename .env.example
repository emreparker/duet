# ── Required ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://duet:your_password@localhost:5432/duet

# Session encryption secret — generate a random string (e.g. openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string

# ── Optional ──────────────────────────────────────────────────
# Server port (default: 7777)
# PORT=7777

# Public URL of your Duet instance (for OAuth redirects)
# APP_URL=https://duet.yourdomain.com

# ── Google Calendar Sync (optional) ───────────────────────────
# Create credentials at https://console.cloud.google.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:7777/api/calendar/callback
